    "    frames = extract_video_frames(one_video_path)\n",
    "\n",
    "    if frames is not None and len(frames) == SEQUENCE_LENGTH:\n",
    "        X.append(frames)\n",
    "        y.append(one_label)\n",
    "\n",
    "X = np.array(X)\n",
    "y = np.array(y)\n",
    "\n",
    "print(\"X shape:\", X.shape)\n",
    "print(\"y shape:\", y.shape)\n",
    "print(\"Class distribution:\")\n",
    "for class_name, class_idx in CLASS_TO_INDEX.items():\n",
    "    print(f\"{class_name}: {np.sum(y == class_idx)}\")"
   ]
